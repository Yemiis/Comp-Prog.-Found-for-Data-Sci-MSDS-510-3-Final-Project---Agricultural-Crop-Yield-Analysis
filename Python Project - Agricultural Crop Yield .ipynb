   "source": [
    "# ----------------------------------------------------\n",
    "# Step 2: Load & Preview Dataset with pandas\n",
    "# ----------------------------------------------------\n",
    "\n",
    "# Adjust this path if your file is in a different location\n",
    "file_path = r\"C:\\Users\\lawra\\Downloads\\crop_yield.csv\"\n",
    "\n",
    "# Load the CSV with pandas\n",
    "df = pd.read_csv(file_path)\n",
    "\n",
    "print(\"Dataset loaded successfully.\")\n",
    "display(df.head())\n",
    "\n",
    "print(f\"Shape: {df.shape[0]} rows × {df.shape[1]} columns\")\n",
    "\n",
    "# Build schema table instead of using df.info() text output\n",
    "schema_table = pd.DataFrame({\n",
    "    \"Column\": df.columns,\n",
    "    \"Dtype\": df.dtypes.values,\n",
    "    \"Non-Null Count\": df.notnull().sum().values\n",
    "})\n",
    "\n",
    "print(\"\\nDataset Schema (Table Format):\")\n",
    "display(schema_table)\n",
    "\n",
    "print(\"\\nVariables (columns):\")\n",
    "display(pd.DataFrame({\"Variables\": df.columns}))\n",
    "\n",
    "\n",
    "# ----------------------------------------------------\n",
    "# Step 2b: Assignment Part 2 — csv module helper function\n",
    "# ----------------------------------------------------\n",
    "\n",
    "def load_csv_as_list_of_dicts(path: str):\n",
    "    \"\"\"\n",
    "    Load a CSV file using the built-in csv module and return a list of dictionaries.\n",
    "    Each dictionary represents one row with column names as keys.\n",
    "    \"\"\"\n",
    "    rows = []\n",
    "    with open(path, \"r\", encoding=\"utf-8\", newline=\"\") as f:\n",
    "        reader = csv.DictReader(f)\n",
    "        for row in reader:\n",
    "            rows.append(row)\n",
    "    return rows\n",
    "\n",
    "\n",
    "raw_rows = load_csv_as_list_of_dicts(file_path)\n",
    "\n",
    "# Part 2 outputs from csv module (variables, sample dict, row count)\n",
    "header_vars = list(raw_rows[0].keys()) if raw_rows else []\n",
    "first_row = raw_rows[0] if raw_rows else {}\n",
    "row_count = len(raw_rows)\n",
    "\n",
    "print(\"\\nPart 2 — CSV module checkpoint\")\n",
    "print(\"Variables from header:\")\n",
    "display(pd.DataFrame({\"Variables\": header_vars}))\n",
    "\n",
    "print(\"Sample dictionary row (first data row):\")\n",
    "display(pd.DataFrame([first_row]))\n",
    "\n",
    "print(\"Total row count (csv-level):\")\n",
    "display(pd.DataFrame([{\"Row Count\": row_count}]))"
   ]
  },
