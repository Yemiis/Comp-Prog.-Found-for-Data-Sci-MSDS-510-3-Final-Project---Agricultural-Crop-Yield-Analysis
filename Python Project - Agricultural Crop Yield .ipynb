    "# ----------------------------------------------------\n",
    "# Step 6: Visualization\n",
    "# ----------------------------------------------------\n",
    "\n",
    "# Bar — Average Yield by Crop\n",
    "plt.figure(figsize=(10, 5))\n",
    "sns.barplot(x=avg_yield_by_crop.index, y=avg_yield_by_crop.values)\n",
    "plt.title(\"Average Yield by Crop (t/ha)\")\n",
    "plt.xlabel(\"Crop\")\n",
    "plt.ylabel(\"Average Yield (t/ha)\")\n",
    "plt.xticks(rotation=45, ha=\"right\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Bar — Average Yield by Region\n",
    "plt.figure(figsize=(8, 5))\n",
    "sns.barplot(x=avg_yield_by_region.index, y=avg_yield_by_region.values)\n",
    "plt.title(\"Average Yield by Region (t/ha)\")\n",
    "plt.xlabel(\"Region\")\n",
    "plt.ylabel(\"Average Yield (t/ha)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Box — Yield by Irrigation Use\n",
    "plt.figure(figsize=(8, 5))\n",
    "sns.boxplot(data=df, x=\"Irrigation_Used\", y=\"Yield_tons_per_hectare\")\n",
    "plt.title(\"Yield Distribution by Irrigation Use\")\n",
    "plt.xlabel(\"Irrigation_Used\")\n",
    "plt.ylabel(\"Yield (t/ha)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Scatter — Yield vs Rainfall colored by Irrigation\n",
    "plt.figure(figsize=(8, 5))\n",
    "sns.scatterplot(\n",
    "    data=df,\n",
    "    x=\"Rainfall_mm\",\n",
    "    y=\"Yield_tons_per_hectare\",\n",
    "    hue=\"Irrigation_Used\",\n",
    "    alpha=0.7,\n",
    ")\n",
    "plt.title(\"Yield vs Rainfall (colored by Irrigation)\")\n",
    "plt.xlabel(\"Rainfall (mm)\")\n",
    "plt.ylabel(\"Yield (t/ha)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Heatmap — Correlation among numeric variables\n",
    "plt.figure(figsize=(10, 6))\n",
    "corr = df.corr(numeric_only=True)\n",
    "sns.heatmap(corr, annot=True, center=0)\n",
    "plt.title(\"Correlation Heatmap (numeric variables)\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n"
   ]
  },
