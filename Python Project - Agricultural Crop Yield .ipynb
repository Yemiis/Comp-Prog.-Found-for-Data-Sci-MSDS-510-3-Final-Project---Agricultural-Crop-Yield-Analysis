    "# ----------------------------------------------------\n",
    "# Step 5: Use the Class to Answer Questions\n",
    "# ----------------------------------------------------\n",
    "\n",
    "# Create analyzer object, reusing cleaned df\n",
    "an = CropYieldAnalyzer(file_path, dataframe=df)\n",
    "\n",
    "# Also load the list-of-dicts version for assignment completeness\n",
    "_ = an.load_with_csv_module()\n",
    "\n",
    "# Core artifacts\n",
    "variables = an.list_variables()\n",
    "sample_row = an.sample_entry(0)\n",
    "n_rows = an.row_count()\n",
    "\n",
    "print(\"\\nVariables (table):\")\n",
    "display(pd.DataFrame({\"Variables\": variables}))\n",
    "\n",
    "print(\"\\nSample dictionary row (first row):\")\n",
    "display(pd.DataFrame([sample_row]))\n",
    "\n",
    "print(\"\\nTotal number of rows:\")\n",
    "display(pd.DataFrame([{\"Total Rows\": n_rows}]))\n",
    "\n",
    "# Analysis questions from the project\n",
    "avg_rain_by_region = an.average_by_category(\"Rainfall_mm\", \"Region\")\n",
    "pct_wheat_in_west = an.percentage_of_category(\"Crop\", \"Wheat\", \"Region\", \"West\")\n",
    "pct_barley_gt5 = an.percentage_numeric_greater(\n",
    "    \"Crop\", \"Barley\", \"Yield_tons_per_hectare\", 5.0\n",
    ")\n",
    "avg_yield_by_crop = an.average_by_category(\"Yield_tons_per_hectare\", \"Crop\")\n",
    "avg_yield_by_region = an.average_by_category(\"Yield_tons_per_hectare\", \"Region\")\n",
    "\n",
    "print(\"\\nAverage Rainfall by Region (mm):\")\n",
    "display(avg_rain_by_region.to_frame(\"Avg Rainfall (mm)\"))\n",
    "\n",
    "print(\"\\nPercent of Wheat in West:\")\n",
    "display(pd.DataFrame([{\"% Wheat in West\": pct_wheat_in_west}]))\n",
    "\n",
    "print(\"\\nPercent of Barley with Yield > 5 t/ha:\")\n",
    "display(pd.DataFrame([{\"% Barley Yield >5\": pct_barley_gt5}]))\n",
    "\n",
    "print(\"\\nAverage Yield by Crop (t/ha):\")\n",
    "display(avg_yield_by_crop.to_frame(\"Avg Yield (t/ha)\"))\n",
    "\n",
    "print(\"\\nAverage Yield by Region (t/ha):\")\n",
    "display(avg_yield_by_region.to_frame(\"Avg Yield (t/ha)\"))\n",
    "\n"
   ]
  },
