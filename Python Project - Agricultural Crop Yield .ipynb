   "cell_type": "markdown",
   "id": "0f11feb4-5c5b-4a6a-aed6-ff06a1f57aa3",
   "metadata": {},
   "source": [
    "# ----------------------------------------------------\n",
    "# Step 4: Class Design — CropYieldAnalyzer\n",
    "# ----------------------------------------------------"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "f95af535-650a-4b38-9a25-a5f293358dbe",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ----------------------------------------------------\n",
    "# Step 4: Class Design — CropYieldAnalyzer\n",
    "# ----------------------------------------------------\n",
    "\n",
    "class CropYieldAnalyzer:\n",
    "    \"\"\"Encapsulates loading, analyzing, and reporting on the crop_yield dataset.\"\"\"\n",
    "\n",
    "    def __init__(self, path: str, dataframe: pd.DataFrame | None = None):\n",
    "        \"\"\"\n",
    "        Core properties:\n",
    "          - path: Path to the CSV file on disk\n",
    "          - df: pandas DataFrame with cleaned data\n",
    "          - rows_list: list-of-dicts version of the same data (csv module)\n",
    "        \"\"\"\n",
    "        self.path = Path(path)\n",
    "        self.df = dataframe\n",
    "        self.rows_list: list[dict] = []\n",
    "\n",
    "    # ---------- Loading methods ----------\n",
    "\n",
    "    def load_with_pandas(self):\n",
    "        \"\"\"Load CSV into a pandas DataFrame and store it in self.df.\"\"\"\n",
    "        self.df = pd.read_csv(self.path)\n",
    "        return self.df\n",
    "\n",
    "    def load_with_csv_module(self):\n",
    "        \"\"\"\n",
    "        Load CSV using csv.DictReader and store it\n",
    "        as a list of dictionaries in self.rows_list.\n",
    "        \"\"\"\n",
    "        self.rows_list = []\n",
    "        with self.path.open(\"r\", encoding=\"utf-8\", newline=\"\") as f:\n",
    "            reader = csv.DictReader(f)\n",
    "            for row in reader:\n",
    "                self.rows_list.append(row)\n",
    "        return self.rows_list\n",
    "\n",
    "    # ---------- Basic structure inspection ----------\n",
    "\n",
    "    def list_variables(self):\n",
    "        \"\"\"Return column names as a list.\"\"\"\n",
    "        return list(self.df.columns)\n",
    "\n",
    "    def sample_entry(self, index: int = 0):\n",
    "        \"\"\"\n",
    "        Return a sample row as a plain Python dictionary (col -> value).\n",
    "        Demonstrates using dictionary structures from the DataFrame.\n",
    "        \"\"\"\n",
    "        idx = max(0, min(index, len(self.df) - 1))\n",
    "        return self.df.iloc[idx].to_dict()\n",
    "\n",
    "    def row_count(self):\n",
    "        \"\"\"Return total number of rows in the DataFrame.\"\"\"\n",
    "        return len(self.df)\n",
    "\n",
    "    # ---------- Analysis methods ----------\n",
    "\n",
    "    def average_by_category(self, numeric_col: str, category_col: str):\n",
    "        \"\"\"\n",
    "        Return the average of a numeric column grouped by a category\n",
    "        as a pandas Series (index = category, values = mean).\n",
    "        \"\"\"\n",
    "        s = pd.to_numeric(self.df[numeric_col], errors=\"coerce\")\n",
    "        return s.groupby(self.df[category_col]).mean().sort_values(ascending=False)\n",
    "\n",
    "    def percentage_of_category(\n",
    "        self,\n",
    "        category_col: str,\n",
    "        target_value,\n",
    "        within_col: str | None = None,\n",
    "        within_value=None\n",
    "    ):\n",
    "        \"\"\"\n",
    "        Percentage of rows where category_col == target_value.\n",
    "        Optionally limit to rows where within_col == within_value.\n",
    "        \"\"\"\n",
    "        sub = self.df if within_col is None else self.df[self.df[within_col] == within_value]\n",
    "        denom = len(sub)\n",
    "        if denom == 0:\n",
    "            return np.nan\n",
    "        num = (sub[category_col] == target_value).sum()\n",
    "        return 100.0 * num / denom\n",
    "\n",
    "    def percentage_numeric_greater(\n",
    "        self,\n",
    "        filter_col: str,\n",
    "        filter_value,\n",
    "        numeric_col: str,\n",
    "        threshold: float\n",
    "    ):\n",
    "        \"\"\"\n",
    "        Within rows where filter_col == filter_value,\n",
    "        return the percentage of rows where numeric_col > threshold.\n",
    "        \"\"\"\n",
    "        sub = self.df[self.df[filter_col] == filter_value]\n",
    "        if sub.empty:\n",
    "            return np.nan\n",
    "        vals = pd.to_numeric(sub[numeric_col], errors=\"coerce\").dropna()\n",
    "        if vals.empty:\n",
    "            return np.nan\n",
    "        return 100.0 * (vals > threshold).mean()  # fraction * 100 gives percent\n",
    "\n",
    "    # ---------- Reporting method ----------\n",
    "\n",
    "    def write_results_to_text(self, output_path: str, results: dict):\n",
    "        \"\"\"\n",
    "        Write key results to a plain text file (Part 4 requirement).\n",
    "        Each line is 'label: value'.\n",
    "        \"\"\"\n",
    "        with open(output_path, \"w\", encoding=\"utf-8\") as f:\n",
    "            f.write(\"Crop Yield Analysis – Key Results\\n\")\n",
    "            f.write(\"=================================\\n\\n\")\n",
    "            for label, value in results.items():\n",
    "                f.write(f\"{label}:\\n{value}\\n\\n\")\n",
    "        print(f\"Results written to {output_path}\")\n",
    "\n"
   ]
  },
