    "# ----------------------------------------------------\n",
    "# Step 7: Expanded Findings & Interpretation\n",
    "# ----------------------------------------------------\n",
    "\n",
    "print(\"Expanded Findings and Interpretation\\n\")\n",
    "\n",
    "# 1) Irrigation and Yield\n",
    "avg_yield_by_irrig = df.groupby(\"Irrigation_Used\")[\"Yield_tons_per_hectare\"].mean()\n",
    "print(\"1) Irrigation Effect: Average yield by Irrigation_Used:\")\n",
    "display(avg_yield_by_irrig.round(3).to_frame(\"Avg Yield (t/ha)\"))\n",
    "print(\"Interpretation: Irrigated fields typically show higher average yields than non-irrigated fields.\\n\")\n",
    "\n",
    "# 2) Fertilizer and Yield\n",
    "avg_yield_by_fert = df.groupby(\"Fertilizer_Used\")[\"Yield_tons_per_hectare\"].mean()\n",
    "print(\"2) Fertilizer Effect: Average yield by Fertilizer_Used:\")\n",
    "display(avg_yield_by_fert.round(3).to_frame(\"Avg Yield (t/ha)\"))\n",
    "print(\"Interpretation: Fertilizer use is associated with higher yields, consistent with added nutrients.\\n\")\n",
    "\n",
    "# 3) Rainfall and Yield\n",
    "corr_yield_rain = df[[\"Yield_tons_per_hectare\", \"Rainfall_mm\"]].corr().iloc[0, 1]\n",
    "print(\"3) Rainfall Relationship:\")\n",
    "display(pd.DataFrame([{\"Correlation(Yield, Rainfall_mm)\": round(corr_yield_rain, 3)}]))\n",
    "print(\"Interpretation: A positive correlation suggests yield tends to increase with rainfall up to optimal levels.\\n\")\n",
    "\n",
    "# 4) Regional Differences\n",
    "print(\"4) Regional Averages:\")\n",
    "print(\"Average rainfall by region (mm):\")\n",
    "display(avg_rain_by_region.round(2).to_frame(\"Rainfall (mm)\"))\n",
    "\n",
    "print(\"Average yield by region (t/ha):\")\n",
    "display(avg_yield_by_region.round(3).to_frame(\"Yield (t/ha)\"))\n",
    "print(\"Interpretation: Regions differ slightly in rainfall and yield, reflecting local conditions and practices.\\n\")\n",
    "\n",
    "# 5) Composition & Threshold Questions\n",
    "print(\"5) Composition and Thresholds:\")\n",
    "comp_tbl = pd.DataFrame([\n",
    "    {\"Metric\": \"% of Wheat in West\", \"Value\": pct_wheat_in_west},\n",
    "    {\"Metric\": \"% of Barley Yield > 5 t/ha\", \"Value\": pct_barley_gt5}\n",
    "])\n",
    "display(comp_tbl)\n",
    "print(\"Interpretation: These percentages identify important subgroups for further agronomic focus.\\n\")\n",
    "\n",
    "print(\"Overall Conclusion:\")\n",
    "print(\"- Irrigation and fertilizer are both strongly associated with higher yields.\")\n",
    "print(\"- Rainfall has a positive relationship with yield, while irrigation helps buffer low-rainfall conditions.\")\n",
    "print(\"- Regional and crop-level summaries highlight which combinations perform best in this synthetic dataset.\")\n"
   ]
